{
  "name": "@despia/oauth",
  "version": "0.4.1",
  "description": "OAuth for Despia apps. Native ASWebAuthenticationSession (iOS) and Chrome Custom Tabs (Android) via the Despia URL-scheme bridge. Drop-in oauth.google() / oauth.apple() / oauth.tiktok() / oauth.custom() helpers and <despia-oauth-callback> / <despia-oauth-tokens> web components. Works with React, Vue, Svelte, Supabase, Convex, Firebase, custom backends. Zero runtime dependencies.",
  "keywords": [
    "despia",
    "oauth",
    "oauth2",
    "google-signin",
    "apple-signin",
    "sign-in-with-apple",
    "tiktok-login",
    "supabase",
    "convex",
    "firebase",
    "react",
    "vue",
    "svelte",
    "web-components",
    "custom-elements",
    "ios",
    "android",
    "aswebauthenticationsession",
    "chrome-custom-tabs"
  ],
  "license": "MIT",
  "author": "Despia",
  "homepage": "https://github.com/despia-native/despia-oauth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/despia-native/despia-oauth.git"
  },
  "bugs": {
    "url": "https://github.com/despia-native/despia-oauth/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/umd/despia-oauth.min.js",
  "jsdelivr": "./dist/umd/despia-oauth.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web-components": {
      "types": "./dist/web-components/index.d.ts",
      "import": "./dist/web-components/index.js",
      "require": "./dist/web-components/index.cjs"
    },
    "./web-components/manual": {
      "types": "./dist/web-components/manual.d.ts",
      "import": "./dist/web-components/manual.js",
      "require": "./dist/web-components/manual.cjs"
    },
    "./server/apple-form-post": {
      "types": "./dist/server/apple-form-post.d.ts",
      "import": "./dist/server/apple-form-post.js",
      "require": "./dist/server/apple-form-post.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsup --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "jsdom": "^23.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
